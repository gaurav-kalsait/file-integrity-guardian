# ===========================
# File Integrity Guardian
# .gitignore
# ===========================

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
venv/
env/
.venv/

# Backend data (local scan data — do NOT upload)
backend/fig_data/

# Node / React
frontend/node_modules/
frontend/dist/
frontend/.vite/
*.log
npm-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Environment
.env
.env.local
.env.production

# Generated PPT (optional — remove this line if you want to include it)
*.pptx